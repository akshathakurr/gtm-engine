# Secrets
.env
.env.local

# User context — keep .example committed, ignore the rest (including archives
# in subfolders, which hold private business data and must never be published)
context/*.md
context/**/*.md
!context/*.md.example
!context/**/*.md.example

# User skills — same pattern (but keep the folder's own README + example)
skills/*.md
!skills/*.md.example
!skills/README.md

# Workflow outputs
outputs/
workflows/*/outputs/
workflows/**/results.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code local state
.claude/
