# Anthropic — required for any LLM-driven workflow
ANTHROPIC_API_KEY=

# Apify — required for LinkedIn / Twitter / review scrapers
APIFY_API_TOKEN=

# Web search — set EITHER or BOTH of the two below. With only one set, that
# one is used. With both set, Exa is primary and Parallel is the automatic
# fallback (see SEARCH_PROVIDER). At least one is needed for Web Search,
# Competitor Analysis, and the outreach workflows.

# Exa — semantic search with native date/domain filters. exa.ai
EXA_API_KEY=

# Parallel — LLM-optimized web search. Good as a backup for Exa (rate limits /
# exhausted credits) or as your only provider. Get a key at platform.parallel.ai
PARALLEL_API_KEY=

# Optional search controls:
#   SEARCH_PROVIDER=auto  # auto (default) | exa | parallel | both
#   SEARCH_PRIMARY=exa    # when both keys set: exa (default) | parallel
#   SEARCH_PARALLEL_MODE=basic  # turbo (fast/cheap) | basic | advanced (best)
#     (legacy SEARCH_PARALLEL_PROCESSOR=base/pro still maps to basic/advanced)

# Apollo — optional, only for Contact Finder (email lookup)
APOLLO_API_KEY=

# Firecrawl — optional, for Competitor Analysis to rescue JS-rendered
# pricing / case-study pages (free tier: 1,000 pages/month). Get one at
# firecrawl.dev. Without it, those pages just fall back to the static scrape.
FIRECRAWL_API_KEY=
