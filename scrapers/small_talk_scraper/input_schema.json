{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Small Talk Scraper Input",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name":        {"type": "string", "description": "Full name of the prospect"},
    "company":     {"type": "string", "description": "Company name (helps disambiguate identity)"},
    "profile_url": {"type": "string", "description": "LinkedIn profile URL (optional — used only as an identity anchor)"},
    "website":     {"type": "string", "description": "Personal website (optional — identity anchor)"},
    "max_signals": {"type": "integer", "default": 3, "description": "Max small-talk signals to return"},
    "num_queries": {"type": "integer", "default": 3, "description": "Targeted web search queries to generate"}
  }
}
