{
  "title": "LinkedIn Company Post Scraper Input",
  "type": "object",
  "properties": {
    "company_url": {
      "type": "string",
      "description": "LinkedIn company page URL (e.g. https://www.linkedin.com/company/anthropic/)"
    },
    "max_posts": {
      "type": "integer",
      "default": 10,
      "minimum": 1,
      "maximum": 100,
      "description": "Maximum number of posts to return. Defaults to 10."
    }
  },
  "required": ["company_url"]
}
