      "hashtags": [],
      "mentions": []
    },
    {
      "id": "2036907742573494373",
      "text": "I now get so many AI-generated replies that it's just too much work to report them for spam and block them, so I'm downshifting to muting.",
      "created_at": "Wed Mar 25 20:47:04 +0000 2026",
      "url": "https://twitter.com/paulg/status/2036907742573494373",
      "likes": 803,
      "retweets": 9,
      "replies": 196,
      "quotes": 9,
